{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Go API Server",
      "runtimeExecutable": "/usr/local/go/bin/go",
      "runtimeArgs": ["run", "./cmd/server"],
      "cwd": "server",
      "port": 8080
    },
    {
      "name": "Dashboard (Next.js)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["dev.sh"],
      "cwd": "dashboard",
      "port": 3000
    },
    {
      "name": "Website (Astro)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:$PATH && node node_modules/.bin/astro dev"],
      "cwd": "website",
      "port": 4321
    },
    {
      "name": "Docs (Docusaurus)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:$PATH && node node_modules/.bin/docusaurus start --port 3001"],
      "cwd": "docs",
      "port": 3001
    }
  ]
}
