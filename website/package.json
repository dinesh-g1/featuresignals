{
  "name": "featuresignals-website",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "next build && bash scripts/fix-double-dots.sh out",
    "start": "next start --port 3002",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@primer/css": "^22.1.1",
    "@radix-ui/react-accordion": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-navigation-menu": "^1",
    "@radix-ui/react-tabs": "^1",
    "@scalar/api-reference": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "framer-motion": "^12",
    "lucide-react": "^1",
    "next": "16.2.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.12.0"
  }
