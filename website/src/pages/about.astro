---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About">
  <section class="mx-auto max-w-4xl px-6 py-24 text-center">
    <div class="inline-block rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 mb-6 ring-1 ring-indigo-100">
      Coming Soon
    </div>
    <h1 class="text-4xl font-bold text-slate-900">About FeatureSignals</h1>
    <p class="mt-4 text-slate-500 max-w-lg mx-auto leading-relaxed">
      We're building the feature management platform we always wanted — transparent, developer-first, and enterprise-ready. More details coming soon.
    </p>
    <a href="/" class="mt-8 inline-block rounded-lg border border-slate-300 px-6 py-2.5 text-sm font-medium text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-400">Back to Home</a>
  </section>
</Layout>
