---
import Layout from '../layouts/Layout.astro';

const rows = [
  { feature: "Projects", free: "1", pro: "Unlimited", enterprise: "Unlimited" },
  { feature: "Environments", free: "2", pro: "Unlimited", enterprise: "Unlimited" },
  { feature: "Flags & Evaluations", free: "Unlimited", pro: "Unlimited", enterprise: "Unlimited" },
  { feature: "Team members", free: "3", pro: "Unlimited", enterprise: "Unlimited" },
  { feature: "SSO", free: "—", pro: "SAML, OIDC", enterprise: "SAML, OIDC, SCIM" },
  { feature: "Audit log", free: "—", pro: "90 days", enterprise: "Unlimited" },
  { feature: "Approval workflows", free: "—", pro: "—", enterprise: "Yes" },
  { feature: "On-premises / Private cloud", free: "—", pro: "—", enterprise: "Yes" },
  { feature: "Support", free: "Community", pro: "Email (24h)", enterprise: "Dedicated (4h SLA)" },
];
---
<Layout title="Pricing">
  <section class="mx-auto max-w-6xl px-6 py-20">
    <h1 class="text-center text-4xl font-bold text-slate-900">Pricing that scales with you</h1>
    <p class="mt-3 text-center text-slate-500">No per-MAU charges. No per-evaluation fees. Just simple, predictable pricing.</p>

    <div class="mt-16 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-slate-200 bg-slate-50">
            <th class="py-4 pl-6 pr-4 font-medium text-slate-500">Feature</th>
            <th class="py-4 px-4 font-semibold text-slate-900">Free</th>
            <th class="py-4 px-4 font-semibold text-indigo-600">Pro ($49/seat)</th>
            <th class="py-4 px-4 font-semibold text-slate-900">Enterprise ($149/seat)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rows.map((row, i) => (
            <tr class:list={[i % 2 === 1 ? "bg-slate-50/50" : "bg-white", "transition-colors hover:bg-indigo-50/30"]}>
              <td class="py-3 pl-6 pr-4 font-medium text-slate-700">{row.feature}</td>
              <td class="px-4 text-slate-600">{row.free}</td>
              <td class="px-4 text-slate-600">{row.pro}</td>
              <td class="px-4 text-slate-600">{row.enterprise}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
