---
import Layout from '../layouts/Layout.astro';
import pricingData from '../../pricing.json';

const free = pricingData.plans.free;
const pro = pricingData.plans.pro;
const enterprise = pricingData.plans.enterprise;
const checkSvg = `<svg class="h-4 w-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;
const checkSvgIndigo = `<svg class="h-4 w-4 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;
---
<Layout title="Pricing" description="Start free, upgrade when you're ready. FeatureSignals offers a generous free tier, a Pro plan for growing teams, and Enterprise for custom needs.">
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center">
      <div class="inline-block rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 mb-6 ring-1 ring-indigo-100">
        Simple, transparent pricing
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">Start free. Scale as you grow.</h1>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto">
        Every plan includes the full feature set. Pick the one that matches your team size and support needs.
      </p>
      <p class="mt-3 text-sm text-slate-400">
        Not sure yet? <a href="https://demo.featuresignals.com/demo" class="font-medium text-indigo-600 underline decoration-indigo-300 hover:text-indigo-700">Try the live demo</a> — no account required.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 lg:grid-cols-3 max-w-5xl mx-auto items-start">

      <div class="rounded-2xl border border-slate-200 bg-white p-8 text-left transition-all hover:shadow-lg hover:border-slate-300">
        <h3 class="text-lg font-semibold text-slate-900">{free.name}</h3>
        <p class="mt-1 text-sm text-slate-500">{free.tagline}</p>
        <p class="mt-4 text-4xl font-bold text-slate-900">{free.display_price}<span class="text-base font-normal text-slate-500"> / {free.billing_period}</span></p>
        <ul class="mt-8 space-y-3 text-sm text-slate-600">
          {free.features.map((f: string) => (
            <li class="flex items-center gap-2"><Fragment set:html={checkSvg} />{f}</li>
          ))}
        </ul>
        <a href={free.cta_url} class="mt-8 block rounded-lg border border-slate-300 py-3 text-center text-sm font-semibold text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-400">{free.cta_label}</a>
      </div>

      <div class="rounded-2xl border-2 border-indigo-600 bg-white p-8 text-left relative shadow-xl shadow-indigo-100 lg:-mt-4 lg:pb-10">
        <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-indigo-600 px-4 py-1 text-xs font-semibold text-white">Most Popular</span>
        <h3 class="text-lg font-semibold text-slate-900">{pro.name}</h3>
        <p class="mt-1 text-sm text-slate-500">{pro.tagline}</p>
        <p class="mt-4 text-4xl font-bold text-slate-900">{pro.display_price}<span class="text-base font-normal text-slate-500"> / {pro.billing_period}</span></p>
        <ul class="mt-8 space-y-3 text-sm text-slate-600">
          {pro.features.map((f: string) => (
            <li class="flex items-center gap-2"><Fragment set:html={checkSvgIndigo} />{f}</li>
          ))}
        </ul>
        <a href={pro.cta_url} class="mt-8 block rounded-lg bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition-all hover:bg-indigo-700 hover:shadow-md">{pro.cta_label}</a>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-8 text-left transition-all hover:shadow-lg hover:border-slate-300">
        <h3 class="text-lg font-semibold text-slate-900">{enterprise.name}</h3>
        <p class="mt-1 text-sm text-slate-500">{enterprise.tagline}</p>
        <p class="mt-4 text-4xl font-bold text-slate-900">{enterprise.display_price}</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-600">
          {enterprise.features.map((f: string) => (
            <li class="flex items-center gap-2"><Fragment set:html={checkSvgIndigo} />{f}</li>
          ))}
        </ul>
        <a href={enterprise.cta_url} class="mt-8 block rounded-lg border border-slate-300 py-3 text-center text-sm font-semibold text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-400">{enterprise.cta_label}</a>
      </div>

    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-slate-500">Want to explore first?</p>
      <a href="https://demo.featuresignals.com/demo" class="mt-2 inline-flex items-center gap-2 rounded-lg bg-indigo-50 px-5 py-2.5 text-sm font-semibold text-indigo-700 ring-1 ring-indigo-100 transition-all hover:bg-indigo-100 hover:ring-indigo-200">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" /></svg>
        Try the Live Demo — No Sign-Up Required
      </a>
    </div>
  </section>

  <section class="border-t border-slate-100 bg-slate-50 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-2xl font-bold text-slate-900">Every plan includes</h2>
      <p class="mt-2 text-center text-slate-500">No feature gating. The full platform from day one.</p>
      <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-4 max-w-4xl mx-auto">
        {pricingData.common_features.map((f: string) => (
          <div class="rounded-lg border border-slate-200 bg-white p-4 text-center transition-all hover:shadow-md">
            <p class="font-semibold text-slate-900 text-sm">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-2xl font-bold text-slate-900">Self-hosting cost estimates</h2>
      <p class="mt-2 text-center text-slate-500">For teams who prefer to run on their own infrastructure. The software is always free.</p>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3 max-w-3xl mx-auto">
        {pricingData.self_hosting.map((s: { tier: string; estimate: string; description: string }) => (
          <div class="rounded-xl border border-slate-200 p-6 text-center">
            <h3 class="font-semibold text-slate-900">{s.tier}</h3>
            <p class="mt-2 text-3xl font-bold text-indigo-600">{s.estimate}</p>
            <p class="mt-3 text-xs text-slate-500">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-slate-100 py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-center text-2xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="mt-10 space-y-6">
        <div class="border-b border-slate-100 pb-6">
          <h3 class="font-semibold text-slate-900">Can I try before I sign up?</h3>
          <p class="mt-2 text-sm text-slate-600">Absolutely. Our <a href="https://demo.featuresignals.com/demo" class="text-indigo-600 underline hover:text-indigo-700">live demo</a> gives you full access to the platform with sample data — no account needed. Your data is kept for 7 days, and you can convert to a permanent account any time.</p>
        </div>
        <div class="border-b border-slate-100 pb-6">
          <h3 class="font-semibold text-slate-900">What's the difference between Free and Pro?</h3>
          <p class="mt-2 text-sm text-slate-600">Both plans include the full feature set: all flag types, SDKs, A/B testing, and more. Free is limited to {free.limits.projects} project(s), {free.limits.environments} environments, and {free.limits.seats} team members. Pro removes all limits and adds priority support, RBAC, audit logs, and approval workflows.</p>
        </div>
        <div class="border-b border-slate-100 pb-6">
          <h3 class="font-semibold text-slate-900">Can I self-host instead of using the cloud?</h3>
          <p class="mt-2 text-sm text-slate-600">Yes. FeatureSignals is Apache-2.0 licensed and designed for self-hosting. Use Docker Compose, Kubernetes, or a single binary on any VPS. The <a href="https://docs.featuresignals.com/getting-started/quickstart" class="text-indigo-600 underline hover:text-indigo-700">quickstart guide</a> gets you running in under 5 minutes.</p>
        </div>
        <div class="border-b border-slate-100 pb-6">
          <h3 class="font-semibold text-slate-900">How does billing work?</h3>
          <p class="mt-2 text-sm text-slate-600">Billing is handled via PayU. You can upgrade to Pro from the dashboard at any time. Subscriptions are monthly and can be cancelled anytime.</p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">Do you offer discounts for startups or open-source projects?</h3>
          <p class="mt-2 text-sm text-slate-600">Yes. <a href="mailto:support@featuresignals.com" class="text-indigo-600 underline hover:text-indigo-700">Contact us</a> and we'll work something out.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-br from-indigo-600 to-indigo-800 py-16 text-center text-white">
    <h2 class="text-3xl font-bold">See it in action</h2>
    <p class="mt-3 text-indigo-200">No credit card. No sign-up. Just the product.</p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
      <a href="https://demo.featuresignals.com/demo" class="inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-indigo-600 shadow-sm transition-all hover:bg-indigo-50 hover:shadow-md">Try Live Demo</a>
      <a href="https://app.featuresignals.com/register" class="inline-block rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/10">Sign Up Free</a>
      <a href="https://docs.featuresignals.com" class="inline-block rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/10">Read the Docs</a>
    </div>
  </section>
</Layout>
