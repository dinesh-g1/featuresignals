---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing">
  <section class="mx-auto max-w-6xl px-6 py-20">
    <h1 class="text-center text-4xl font-bold">Pricing that scales with you</h1>
    <p class="mt-3 text-center text-gray-600">No per-MAU charges. No per-evaluation fees. Just simple, predictable pricing.</p>

    <div class="mt-16 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b">
            <th class="py-4 pr-4 font-medium text-gray-500">Feature</th>
            <th class="py-4 px-4 font-semibold">Free</th>
            <th class="py-4 px-4 font-semibold text-blue-600">Pro ($49/seat)</th>
            <th class="py-4 px-4 font-semibold">Enterprise ($149/seat)</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <tr><td class="py-3 pr-4">Projects</td><td class="px-4">1</td><td class="px-4">Unlimited</td><td class="px-4">Unlimited</td></tr>
          <tr><td class="py-3 pr-4">Environments</td><td class="px-4">2</td><td class="px-4">Unlimited</td><td class="px-4">Unlimited</td></tr>
          <tr><td class="py-3 pr-4">Flags & Evaluations</td><td class="px-4">Unlimited</td><td class="px-4">Unlimited</td><td class="px-4">Unlimited</td></tr>
          <tr><td class="py-3 pr-4">Team members</td><td class="px-4">3</td><td class="px-4">Unlimited</td><td class="px-4">Unlimited</td></tr>
          <tr><td class="py-3 pr-4">SSO</td><td class="px-4">-</td><td class="px-4">SAML, OIDC</td><td class="px-4">SAML, OIDC, SCIM</td></tr>
          <tr><td class="py-3 pr-4">Audit log</td><td class="px-4">-</td><td class="px-4">90 days</td><td class="px-4">Unlimited</td></tr>
          <tr><td class="py-3 pr-4">Approval workflows</td><td class="px-4">-</td><td class="px-4">-</td><td class="px-4">Yes</td></tr>
          <tr><td class="py-3 pr-4">On-premises / Private cloud</td><td class="px-4">-</td><td class="px-4">-</td><td class="px-4">Yes</td></tr>
          <tr><td class="py-3 pr-4">Support</td><td class="px-4">Community</td><td class="px-4">Email (24h)</td><td class="px-4">Dedicated (4h SLA)</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</Layout>
