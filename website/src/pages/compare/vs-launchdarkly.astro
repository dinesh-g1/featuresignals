---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="FeatureSignals vs LaunchDarkly">
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-4xl font-bold text-center">FeatureSignals vs LaunchDarkly</h1>
    <p class="mt-4 text-center text-gray-600">A fair, honest comparison of both platforms.</p>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b"><th class="py-3 pr-4 font-medium">Criteria</th><th class="py-3 px-4 font-semibold text-blue-600">FeatureSignals</th><th class="py-3 px-4 font-semibold">LaunchDarkly</th></tr>
        </thead>
        <tbody class="divide-y">
          <tr><td class="py-3 pr-4">Pricing model</td><td class="px-4">Per seat, flat tiers</td><td class="px-4">Per seat + per MAU</td></tr>
          <tr><td class="py-3 pr-4">Cost at 100K MAU</td><td class="px-4">$49/seat (same)</td><td class="px-4">$1,000+/mo for MAU alone</td></tr>
          <tr><td class="py-3 pr-4">Evaluations</td><td class="px-4">Unlimited</td><td class="px-4">Included with MAU tier</td></tr>
          <tr><td class="py-3 pr-4">OpenFeature</td><td class="px-4">Native from day one</td><td class="px-4">Added later as provider</td></tr>
          <tr><td class="py-3 pr-4">On-premises</td><td class="px-4">Single Go binary</td><td class="px-4">Relay Proxy only</td></tr>
          <tr><td class="py-3 pr-4">Data sovereignty</td><td class="px-4">Customer chooses region</td><td class="px-4">US/EU only</td></tr>
          <tr><td class="py-3 pr-4">Stale flag mgmt</td><td class="px-4">Built-in + code scanning</td><td class="px-4">Manual / code refs</td></tr>
          <tr><td class="py-3 pr-4">SDK count</td><td class="px-4">6 (growing)</td><td class="px-4">25+</td></tr>
          <tr><td class="py-3 pr-4">Experimentation</td><td class="px-4">Hooks (use your analytics)</td><td class="px-4">Built-in (additional cost)</td></tr>
        </tbody>
      </table>
    </div>

    <div class="mt-12 rounded-xl bg-blue-50 p-6">
      <h3 class="font-semibold text-blue-800">When to choose FeatureSignals</h3>
      <p class="mt-2 text-sm text-blue-700">If you want predictable pricing, deployment flexibility, and don't need 25+ SDK variants. Best for teams that value transparency and control.</p>
    </div>
  </section>
</Layout>
