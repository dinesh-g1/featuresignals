---
import Layout from '../../layouts/Layout.astro';

const rows = [
  { criteria: "Pricing model", fs: "Per seat, flat tiers", ld: "Per seat + per MAU" },
  { criteria: "Cost at 100K MAU", fs: "$49/seat (same)", ld: "$1,000+/mo for MAU alone" },
  { criteria: "Evaluations", fs: "Unlimited", ld: "Included with MAU tier" },
  { criteria: "OpenFeature", fs: "Native from day one", ld: "Added later as provider" },
  { criteria: "On-premises", fs: "Single Go binary", ld: "Relay Proxy only" },
  { criteria: "Data sovereignty", fs: "Customer chooses region", ld: "US/EU only" },
  { criteria: "Stale flag mgmt", fs: "Built-in + code scanning", ld: "Manual / code refs" },
  { criteria: "SDK count", fs: "6 (growing)", ld: "25+" },
  { criteria: "Experimentation", fs: "Hooks (use your analytics)", ld: "Built-in (additional cost)" },
];
---
<Layout title="FeatureSignals vs LaunchDarkly">
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-4xl font-bold text-center text-slate-900">FeatureSignals vs LaunchDarkly</h1>
    <p class="mt-4 text-center text-slate-500">A fair, honest comparison of both platforms.</p>

    <div class="mt-12 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-slate-200 bg-slate-50">
            <th class="py-3 pl-6 pr-4 font-medium text-slate-500">Criteria</th>
            <th class="py-3 px-4 font-semibold text-indigo-600">FeatureSignals</th>
            <th class="py-3 px-4 font-semibold text-slate-900">LaunchDarkly</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rows.map((row, i) => (
            <tr class:list={[i % 2 === 1 ? "bg-slate-50/50" : "bg-white", "transition-colors hover:bg-indigo-50/30"]}>
              <td class="py-3 pl-6 pr-4 font-medium text-slate-700">{row.criteria}</td>
              <td class="px-4 text-slate-600">{row.fs}</td>
              <td class="px-4 text-slate-600">{row.ld}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-12 rounded-xl bg-indigo-50 p-6 ring-1 ring-indigo-100">
      <h3 class="font-semibold text-indigo-800">When to choose FeatureSignals</h3>
      <p class="mt-2 text-sm leading-relaxed text-indigo-700">If you want predictable pricing, deployment flexibility, and don't need 25+ SDK variants. Best for teams that value transparency and control.</p>
    </div>
  </section>
</Layout>
