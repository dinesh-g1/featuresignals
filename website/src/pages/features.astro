---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "Flag Engine",
    description: "Boolean, string, number, and JSON flag types. Percentage rollouts with consistent hashing. User targeting by attributes. Segment-based rules.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0l2.77-.693a9 9 0 016.208.682l.108.054a9 9 0 006.086.71l3.114-.732a48.524 48.524 0 01-.005-10.499l-3.11.732a9 9 0 01-6.085-.711l-.108-.054a9 9 0 00-6.208-.682L3 4.5M3 15V4.5" />`
  },
  {
    title: "Multi-Environment",
    description: "Dev, staging, production, and custom environments. Per-environment flag states and targeting rules. Copy flag configurations between environments.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3" />`
  },
  {
    title: "SDKs for Every Stack",
    description: "Go, Node.js, Python, Java, React. All SDKs implement OpenFeature providers. Local evaluation with zero-latency after init. SSE streaming for real-time updates.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />`
  },
  {
    title: "Enterprise Governance",
    description: "Tamper-evident audit logs. Approval workflows for production changes. RBAC with per-environment permissions. SSO via SAML and OIDC.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`
  },
  {
    title: "Deploy Anywhere",
    description: "SaaS in your chosen region. Private cloud in your VPC. On-premises with a single Go binary. Air-gap capable with offline license validation.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />`
  }
];
---
<Layout title="Features">
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-4xl font-bold text-center text-slate-900">Everything you need to manage feature flags</h1>
    <p class="mt-4 text-center text-slate-500 max-w-2xl mx-auto">A complete feature management platform built for engineering teams that value speed, control, and transparency.</p>
    <div class="mt-16 space-y-8">
      {features.map((feature) => (
        <div class="group rounded-xl border border-slate-200 bg-white p-6 transition-all hover:shadow-lg hover:border-slate-300">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><Fragment set:html={feature.icon} /></svg>
            </div>
            <div>
              <h2 class="text-xl font-semibold text-slate-900">{feature.title}</h2>
              <p class="mt-2 text-slate-600 leading-relaxed">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
