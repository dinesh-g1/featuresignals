---
interface Props {
  title: string;
  lastUpdated?: string;
}

const { title, lastUpdated = "April 4, 2026" } = Astro.props;
---
<article class="mx-auto max-w-3xl px-4 sm:px-6 py-12 sm:py-20">
  <p class="text-sm font-medium text-indigo-600">Legal</p>
  <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{title}</h1>
  <p class="mt-2 text-sm text-slate-500">Last updated: {lastUpdated}</p>
  <div
    class="mt-10 space-y-6 text-base leading-relaxed text-slate-600 [&_a]:font-medium [&_a]:text-indigo-600 [&_a]:underline [&_a]:decoration-indigo-200 [&_a]:hover:text-indigo-700 [&_h2]:mt-10 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-slate-900 [&_h2:first-child]:mt-0 [&_h3]:mt-6 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-slate-900 [&_li]:mt-1 [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-5 [&_p]:text-slate-600 [&_strong]:font-semibold [&_strong]:text-slate-800 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-5"
  >
    <slot />
  </div>
  <p class="mt-12 text-sm text-slate-500">
    Questions? Contact <a href="mailto:support@featuresignals.com" class="font-medium text-indigo-600 underline decoration-indigo-200 hover:text-indigo-700">support@featuresignals.com</a>.
  </p>
</article>
