---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Open-source feature flag management platform. Self-hosted, Apache-2.0 licensed, with A/B experimentation, real-time updates, and SDKs for every stack." } = Astro.props;

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | FeatureSignals</title>
    <ClientRouter />
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased">
    <nav class="border-b border-slate-100 bg-white/80 backdrop-blur-md sticky top-0 z-50" transition:persist>
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight text-indigo-600 transition-colors hover:text-indigo-700">
          <img src="/favicon.svg" alt="FeatureSignals" class="h-7 w-7" />
          FeatureSignals
        </a>
        <div class="hidden items-center gap-8 md:flex">
          <a href="/features" class:list={["text-sm font-medium transition-colors", currentPath === "/features" || currentPath === "/features/" ? "text-indigo-600" : "text-slate-600 hover:text-slate-900"]}>Features</a>
          <a href="/pricing" class:list={["text-sm font-medium transition-colors", currentPath === "/pricing" || currentPath === "/pricing/" ? "text-indigo-600" : "text-slate-600 hover:text-slate-900"]}>Pricing</a>
          <a href="/changelog" class:list={["text-sm font-medium transition-colors", currentPath === "/changelog" || currentPath === "/changelog/" ? "text-indigo-600" : "text-slate-600 hover:text-slate-900"]}>Changelog</a>
          <a href="/use-cases" class:list={["text-sm font-medium transition-colors", currentPath === "/use-cases" || currentPath === "/use-cases/" ? "text-indigo-600" : "text-slate-600 hover:text-slate-900"]}>Use Cases</a>
          <a href="https://docs.featuresignals.com" class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">Docs</a>
          <a href="https://github.com/dinesh-g1/featuresignals" class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">GitHub</a>
        </div>
        <div class="hidden items-center gap-3 md:flex">
          <a href="https://app.featuresignals.com/register" class="text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-700">Start Free Trial</a>
          <a href="https://app.featuresignals.com/login" class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">Log in</a>
          <a href="https://app.featuresignals.com/register" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-all hover:bg-indigo-700 hover:shadow-md">Sign Up</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center rounded-lg p-2 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900" aria-label="Toggle menu">
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden border-t border-slate-100 md:hidden">
        <div class="space-y-1 px-6 py-4">
          <a href="/features" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Features</a>
          <a href="/pricing" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Pricing</a>
          <a href="/changelog" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Changelog</a>
          <a href="/use-cases" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Use Cases</a>
          <a href="https://docs.featuresignals.com" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Docs</a>
          <hr class="my-2 border-slate-100" />
          <a href="https://github.com/dinesh-g1/featuresignals" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">GitHub</a>
          <a href="https://app.featuresignals.com/register" class="block rounded-lg px-3 py-2 text-sm font-medium text-indigo-600 transition-colors hover:bg-indigo-50 hover:text-indigo-700">Start Free Trial</a>
          <a href="https://app.featuresignals.com/login" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900">Log in</a>
          <a href="https://app.featuresignals.com/register" class="block rounded-lg bg-indigo-600 px-3 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-indigo-700">Sign Up</a>
        </div>
      </div>
    </nav>

    <main transition:animate="fade">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50" transition:animate="fade">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10 sm:py-12">
        <div class="grid grid-cols-2 gap-6 sm:gap-8 md:grid-cols-6">
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Product</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="/features" class="transition-colors hover:text-slate-900">Features</a></li>
              <li><a href="/pricing" class="transition-colors hover:text-slate-900">Pricing</a></li>
              <li><a href="/use-cases" class="transition-colors hover:text-slate-900">Use Cases</a></li>
              <li><a href="/changelog" class="transition-colors hover:text-slate-900">Changelog</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Get Started</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="https://app.featuresignals.com/register" class="font-medium text-indigo-600 transition-colors hover:text-indigo-700">Start Free Trial</a></li>
              <li><a href="https://app.featuresignals.com/register" class="transition-colors hover:text-slate-900">Sign Up Free</a></li>
              <li><a href="https://app.featuresignals.com/login" class="transition-colors hover:text-slate-900">Log in</a></li>
              <li><a href="https://app.featuresignals.com" class="transition-colors hover:text-slate-900">Flag Engine</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Developers</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="https://docs.featuresignals.com" class="transition-colors hover:text-slate-900">Documentation</a></li>
              <li><a href="https://docs.featuresignals.com/api-playground" class="transition-colors hover:text-slate-900">API Playground</a></li>
              <li><a href="https://docs.featuresignals.com/docs/sdks/overview" class="transition-colors hover:text-slate-900">SDKs</a></li>
              <li><a href="https://github.com/dinesh-g1/featuresignals" class="transition-colors hover:text-slate-900">GitHub</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Resources</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="https://docs.featuresignals.com/docs/getting-started/quickstart" class="transition-colors hover:text-slate-900">Quickstart Guide</a></li>
              <li><a href="https://docs.featuresignals.com/docs/tutorials/feature-flag-checkout" class="transition-colors hover:text-slate-900">Tutorials</a></li>
              <li><a href="/about" class="transition-colors hover:text-slate-900">About</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Legal</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="/terms-and-conditions" class="transition-colors hover:text-slate-900">Terms &amp; Conditions</a></li>
              <li><a href="/privacy-policy" class="transition-colors hover:text-slate-900">Privacy Policy</a></li>
              <li><a href="/refund-policy" class="transition-colors hover:text-slate-900">Refund Policy</a></li>
              <li><a href="/cancellation-policy" class="transition-colors hover:text-slate-900">Cancellation Policy</a></li>
              <li><a href="/shipping-policy" class="transition-colors hover:text-slate-900">Shipping Policy</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">Community</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-500">
              <li><a href="https://github.com/dinesh-g1/featuresignals/issues" class="transition-colors hover:text-slate-900">Issues</a></li>
              <li><a href="https://github.com/dinesh-g1/featuresignals/discussions" class="transition-colors hover:text-slate-900">Discussions</a></li>
              <li><a href="mailto:support@featuresignals.com" class="transition-colors hover:text-slate-900">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-slate-200 pt-8 text-center text-xs text-slate-400">
          <p>&copy; 2026 Vivekananda Technology Labs, trading as FeatureSignals. Apache-2.0 License.</p>
          <p class="mt-1">Flat no 308, L5-Block, LIG, Chitrapuri Colony, Manikonda, Hyderabad, Telangana - 500089, India</p>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const iconOpen = document.getElementById('menu-icon-open');
        const iconClose = document.getElementById('menu-icon-close');

        if (btn && menu && iconOpen && iconClose) {
          btn.addEventListener('click', () => {
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden');
            iconOpen.classList.toggle('hidden');
            iconClose.classList.toggle('hidden');
            btn.setAttribute('aria-expanded', String(!isOpen));
          });
        }
      });
    </script>
  </body>
</html>
