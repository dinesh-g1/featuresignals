---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Feature flag management platform with transparent pricing, OpenFeature-native SDKs, and multi-deployment options." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | FeatureSignals</title>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <nav class="border-b border-gray-100">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-xl font-bold text-blue-600">FeatureSignals</a>
        <div class="hidden items-center gap-8 md:flex">
          <a href="/features" class="text-sm text-gray-600 hover:text-gray-900">Features</a>
          <a href="/pricing" class="text-sm text-gray-600 hover:text-gray-900">Pricing</a>
          <a href="/blog" class="text-sm text-gray-600 hover:text-gray-900">Blog</a>
          <a href="/compare/vs-launchdarkly" class="text-sm text-gray-600 hover:text-gray-900">Compare</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://app.featuresignals.com/login" class="text-sm font-medium text-gray-600 hover:text-gray-900">Sign in</a>
          <a href="https://app.featuresignals.com/register" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Get Started Free</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="border-t border-gray-100 bg-gray-50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div>
            <h3 class="text-sm font-semibold">Product</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-500">
              <li><a href="/features" class="hover:text-gray-900">Features</a></li>
              <li><a href="/pricing" class="hover:text-gray-900">Pricing</a></li>
              <li><a href="/changelog" class="hover:text-gray-900">Changelog</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold">Developers</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-500">
              <li><a href="https://docs.featuresignals.com" class="hover:text-gray-900">Documentation</a></li>
              <li><a href="https://docs.featuresignals.com/api-reference" class="hover:text-gray-900">API Reference</a></li>
              <li><a href="https://github.com/featuresignals" class="hover:text-gray-900">GitHub</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold">Company</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-500">
              <li><a href="/about" class="hover:text-gray-900">About</a></li>
              <li><a href="/blog" class="hover:text-gray-900">Blog</a></li>
              <li><a href="https://status.featuresignals.com" class="hover:text-gray-900">Status</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold">Compare</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-500">
              <li><a href="/compare/vs-launchdarkly" class="hover:text-gray-900">vs LaunchDarkly</a></li>
              <li><a href="/compare/vs-unleash" class="hover:text-gray-900">vs Unleash</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-gray-200 pt-8 text-center text-xs text-gray-400">
          &copy; 2026 FeatureSignals. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
