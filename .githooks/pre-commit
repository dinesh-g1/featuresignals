#!/usr/bin/env bash
#
# Pre-commit hook for FeatureSignals.
# Install: make setup (or: git config core.hooksPath .githooks)
#
set -euo pipefail

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
ERRORS=0

# в”Ђв”Ђ Secrets check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if echo "$STAGED_FILES" | grep -qE '\.env$|\.env\.[^e]|credentials|\.pem$|\.key$'; then
  echo "ERROR: Potential secret file staged for commit."
  echo "       Remove it with: git reset HEAD <file>"
  ERRORS=$((ERRORS + 1))
fi

SECRETS_PATTERN='(PRIVATE.KEY|BEGIN RSA|password\s*=\s*["\x27][^\x27"]+|sk_live_|sk_test_)'
for f in $STAGED_FILES; do
  if [ -f "$f" ] && echo "$f" | grep -qvE '\.md$|\.lock$|\.sum$|SKILL\.md$|CLAUDE\.md$'; then
    if git show ":$f" 2>/dev/null | grep -qEi "$SECRETS_PATTERN"; then
      echo "WARNING: Possible secret pattern in $f"
    fi
  fi
done

# в”Ђв”Ђ Go checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GO_CHANGED=$(echo "$STAGED_FILES" | grep '\.go$' || true)
if [ -n "$GO_CHANGED" ]; then
  echo "Running go vet..."
  (cd server && go vet ./... 2>&1) || {
    echo "ERROR: go vet failed"
    ERRORS=$((ERRORS + 1))
  }
fi

# в”Ђв”Ђ TypeScript checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TS_CHANGED=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' | grep '^dashboard/' || true)
if [ -n "$TS_CHANGED" ]; then
  echo "Running tsc --noEmit..."
  (cd dashboard && npx tsc --noEmit 2>&1) || {
    echo "ERROR: TypeScript type check failed"
    ERRORS=$((ERRORS + 1))
  }
fi

if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo "$ERRORS pre-commit error(s) found. Fix them before committing."
  exit 1
fi
