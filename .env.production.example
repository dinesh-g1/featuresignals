# FeatureSignals Production Environment Variables
# Copy this file to .env and fill in the values before deploying.
# NEVER commit the .env file to git.

# --- PostgreSQL ---
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# --- API Server ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# CORS origin for the dashboard (must match the exact dashboard URL)
CORS_ORIGIN=https://app.featuresignals.com

# Database connection string (uses POSTGRES_PASSWORD above)
DATABASE_URL=postgres://fs:${POSTGRES_PASSWORD}@postgres:5432/featuresignals?sslmode=disable

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Dashboard (build-time) ---
# The public URL of the API server, baked into the Next.js build
NEXT_PUBLIC_API_URL=https://api.featuresignals.com
