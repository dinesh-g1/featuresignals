# FeatureSignals Production Environment Variables
# Copy this file to .env and fill in the values before deploying.
# NEVER commit the .env file to git.

# --- PostgreSQL ---
# MUST use hex (URL-safe). Do NOT use base64 (contains +/= which break DB URLs).
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Database Roles ---
# Admin role password (for direct DB access from your laptop via SSH tunnel).
# Generate with: openssl rand -hex 24
DB_ADMIN_PASSWORD=

# Readonly role password (for future team members -- SELECT only).
# Generate with: openssl rand -hex 24
DB_READONLY_PASSWORD=

# --- API Server ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# CORS origin for the dashboard (must match the exact dashboard URL)
CORS_ORIGIN=https://app.featuresignals.com

# Database connection string (uses POSTGRES_PASSWORD above)
DATABASE_URL=postgres://fs:${POSTGRES_PASSWORD}@postgres:5432/featuresignals?sslmode=require

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Dashboard (build-time) ---
# The public URL of the API server, baked into the Next.js build
NEXT_PUBLIC_API_URL=https://api.featuresignals.com

# Canonical app URL (used for cross-domain redirects from demo site)
NEXT_PUBLIC_APP_URL=https://app.featuresignals.com
