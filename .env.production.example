# FeatureSignals Production Environment Variables
# Copy this file to .env and fill in the values before deploying.
# NEVER commit the .env file to git.

# --- PostgreSQL ---
# MUST use hex (URL-safe). Do NOT use base64 (contains +/= which break DB URLs).
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Database Roles ---
# Admin role password (for direct DB access from your laptop via SSH tunnel).
# Generate with: openssl rand -hex 24
DB_ADMIN_PASSWORD=

# Readonly role password (for future team members -- SELECT only).
# Generate with: openssl rand -hex 24
DB_READONLY_PASSWORD=

# --- API Server ---
# Generate with: openssl rand -hex 32
# CRITICAL: All regions MUST share the same JWT_SECRET for cross-region token validity.
JWT_SECRET=

# Database connection string (uses POSTGRES_PASSWORD above)
DATABASE_URL=postgres://fs:${POSTGRES_PASSWORD}@postgres:5432/featuresignals?sslmode=require

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Dashboard (build-time) ---
# The public URL of the API server, baked into the Next.js build
NEXT_PUBLIC_API_URL=https://api.featuresignals.com

# Canonical app URL (used for cross-domain redirects from demo site)
NEXT_PUBLIC_APP_URL=https://app.featuresignals.com

# --- PayU Billing ---
# PAYU_MERCHANT_KEY=
# PAYU_SALT=
# PAYU_MODE=live

# --- Stripe Billing ---
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# STRIPE_PRICE_ID=price_your-pro-plan-price-id
# STRIPE_MODE=live

# --- Super Mode (Internal Developer Access) ---
# Server-controlled — no database column, no client-side bypass.
# SUPER_MODE_DOMAIN=featuresignals.com
# SUPER_MODE_EMAILS=

# --- OpenTelemetry / SigNoz ---
# Async batch exporters — no blocking on the hot path.
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.YOUR_TENANT.signoz.cloud:443
OTEL_INGESTION_KEY=
OTEL_SERVICE_NAME=featuresignals-api
OTEL_SERVICE_REGION=in
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_LOG_LEVEL=warn
OTEL_TRACE_SAMPLE_RATE=0.1
