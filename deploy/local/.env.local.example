# FeatureSignals — Full-Stack Local Docker Environment
#
# Quick start:
#   cp deploy/local/.env.local.example .env.local
#   make local-up            # start without seed data
#   make local-seed          # start with seed data pre-loaded
#   make local-up-caddy      # start with Caddy reverse proxy at http://localhost
#
# All values below are sensible defaults. Adjust only if needed.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=fs
POSTGRES_PASSWORD=fsdev
POSTGRES_DB=featuresignals
DATABASE_URL=postgres://fs:fsdev@postgres:5432/featuresignals?sslmode=disable
DB_PORT=5432

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
JWT_SECRET=local-dev-secret-change-in-production
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# ─── Deployment Mode ─────────────────────────────────────────────────────────
# cloud = SaaS mode (billing, regions, etc.)
# onprem = self-hosted mode (no billing, single region)
DEPLOYMENT_MODE=cloud

# ─── Email ───────────────────────────────────────────────────────────────────
# none = disable email (dev), smtp = SMTP relay, msg91 = MSG91 API
EMAIL_PROVIDER=none
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=FeatureSignals

# ─── Dashboard ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── URLs ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000
