# FeatureSignals — Full-Stack Local Docker Environment
# Usage: cp deploy/local/.env.local.example .env.local
#        make local-up          # start without seed data
#        make local-seed        # start with seed data pre-loaded

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=fs
POSTGRES_PASSWORD=fsdev
POSTGRES_DB=featuresignals
DATABASE_URL=postgres://fs:fsdev@postgres:5432/featuresignals?sslmode=disable

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
JWT_SECRET=local-dev-secret-change-in-production
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# ─── Deployment Mode ─────────────────────────────────────────────────────────
DEPLOYMENT_MODE=cloud

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=none

# ─── Dashboard ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── URLs ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000
