# Regional deployment environment variables.
# Copy to .env on each regional server and fill in the values.
#
# IN region (primary — uses base domains, no regional subdomain):
#   REGION=in
#   DOMAIN_API=api.featuresignals.com
#   DOMAIN_APP=app.featuresignals.com
#
# US region:
#   REGION=us
#   DOMAIN_API=api.us.featuresignals.com
#   DOMAIN_APP=app.us.featuresignals.com
#
# EU region:
#   REGION=eu
#   DOMAIN_API=api.eu.featuresignals.com
#   DOMAIN_APP=app.eu.featuresignals.com

# --- Region ---
REGION=in
DOMAIN_API=api.featuresignals.com
DOMAIN_APP=app.featuresignals.com
DOMAIN_MAIN=featuresignals.com
DOMAIN_DOCS=docs.featuresignals.com

# --- PostgreSQL ---
POSTGRES_PASSWORD=
DB_ADMIN_PASSWORD=
DB_READONLY_PASSWORD=

# --- API Server ---
JWT_SECRET=
LOG_LEVEL=info

# --- Multi-Region Routing (Global Router — IN server only) ---
# Set on the IN (primary) server to proxy requests to regional backends.
# LOCAL_REGION=in
# REGION_ENDPOINTS=us=https://api.us.featuresignals.com,eu=https://api.eu.featuresignals.com

# --- Payment Gateways ---
# US/EU regions use Stripe; IN region uses PayU
PAYMENT_GATEWAY=stripe
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_MODE=test

# --- Email (ZeptoMail) ---
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM_EMAIL=noreply@featuresignals.com
ZEPTOMAIL_FROM_NAME=FeatureSignals
ZEPTOMAIL_BASE_URL=https://api.zeptomail.in

# --- OpenTelemetry / SigNoz ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.us2.signoz.cloud:443
OTEL_INGESTION_KEY=
OTEL_SERVICE_NAME=featuresignals-api
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_LOG_LEVEL=warn
OTEL_TRACE_SAMPLE_RATE=0.1
