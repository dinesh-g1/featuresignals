# Regional deployment environment variables.
# Copy to .env on each regional server and fill in the values.
#
# IN region (primary — uses base domains, no regional subdomain):
#   REGION=in
#   DOMAIN_API=api.featuresignals.com
#   DOMAIN_APP=app.featuresignals.com
#
# US region:
#   REGION=us
#   DOMAIN_API=api.us.featuresignals.com
#   DOMAIN_APP=app.us.featuresignals.com
#
# EU region:
#   REGION=eu
#   DOMAIN_API=api.eu.featuresignals.com
#   DOMAIN_APP=app.eu.featuresignals.com

# --- Region ---
REGION=in
DOMAIN_API=api.featuresignals.com
DOMAIN_APP=app.featuresignals.com
DOMAIN_MAIN=featuresignals.com
DOMAIN_DOCS=docs.featuresignals.com

# --- Multi-region API endpoints (baked into dashboard build) ---
NEXT_PUBLIC_API_URL_US=https://api.us.featuresignals.com
NEXT_PUBLIC_API_URL_EU=https://api.eu.featuresignals.com

# --- PostgreSQL ---
POSTGRES_PASSWORD=
DB_ADMIN_PASSWORD=
DB_READONLY_PASSWORD=

# --- API Server ---
JWT_SECRET=
LOG_LEVEL=info

# --- Email (MSG91) ---
MSG91_AUTH_KEY=
MSG91_EMAIL_TEMPLATE_ID=
MSG91_EMAIL_DOMAIN=mail.featuresignals.com
MSG91_EMAIL_FROM=noreply@mail.featuresignals.com
MSG91_EMAIL_FROM_NAME=Feature Signals

# --- OpenTelemetry / SigNoz ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.us2.signoz.cloud:443
OTEL_INGESTION_KEY=
OTEL_SERVICE_NAME=featuresignals-api
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_LOG_LEVEL=warn
OTEL_TRACE_SAMPLE_RATE=0.1
