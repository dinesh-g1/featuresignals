FROM node:22-alpine AS builder

ARG NEXT_PUBLIC_DASHBOARD_URL=https://app.featuresignals.com

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ENV NEXT_PUBLIC_DASHBOARD_URL=$NEXT_PUBLIC_DASHBOARD_URL
RUN npm run build && npm cache clean --force

FROM alpine:3.19
COPY --from=builder /app/out /dist
CMD ["sh", "-c", "cp -r /dist/* /srv/website/ && echo 'Website ready'"]
