featuresignals.com {
	root * /srv/website
	file_server
	encode gzip

	try_files {path} {path}.html {path}/ =404

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf
	header @static Cache-Control "public, max-age=31536000, immutable"
}

# Note: www.featuresignals.com is intentionally NOT served by Caddy.
# Configure Cloudflare Page Rules to redirect www → apex domain:
#   www.featuresignals.com → https://featuresignals.com (301)

docs.featuresignals.com {
	root * /srv/docs
	file_server
	encode gzip

	try_files {path} {path}.html {path}/ /index.html

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	@static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf
	header @static Cache-Control "public, max-age=31536000, immutable"
}

app.featuresignals.com {
	reverse_proxy dashboard:3000

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

demo.featuresignals.com {
	reverse_proxy demo-dashboard:3000

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

api.featuresignals.com {
	reverse_proxy server:8080

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}
}
