featuresignals.com, www.featuresignals.com {
	root * /srv/website
	file_server
	encode gzip

	try_files {path} {path}.html {path}/ =404

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf
	header @static Cache-Control "public, max-age=31536000, immutable"
}

docs.featuresignals.com {
	root * /srv/docs
	file_server
	encode gzip

	try_files {path} {path}.html {path}/ /index.html

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	@static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf
	header @static Cache-Control "public, max-age=31536000, immutable"
}

app.featuresignals.com {
	reverse_proxy dashboard:3000

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

api.featuresignals.com {
	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Origin "https://app.featuresignals.com"
		header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		header Access-Control-Allow-Headers "Accept, Authorization, Content-Type, X-API-Key"
		header Access-Control-Allow-Credentials "true"
		header Access-Control-Max-Age "300"
		respond "" 204
	}

	reverse_proxy server:8080 {
		header_up X-Forwarded-Proto {scheme}
		header_down -Access-Control-Allow-Origin
		header_down -Access-Control-Allow-Methods
		header_down -Access-Control-Allow-Headers
		header_down -Access-Control-Allow-Credentials
		header_down -Access-Control-Max-Age
	}

	header {
		Access-Control-Allow-Origin "https://app.featuresignals.com"
		Access-Control-Allow-Credentials "true"
		X-Content-Type-Options "nosniff"
		-Server
	}
}
