# FeatureSignals On-Premises Configuration
# Copy to .env and fill in required values.

# --- Required ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Networking ---
# External URLs (adjust for your domain/reverse proxy)
APP_BASE_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Ports ---
API_PORT=8080
DASHBOARD_PORT=3000
DB_PORT=127.0.0.1:5432

# --- Database ---
POSTGRES_DB=featuresignals
POSTGRES_USER=fs

# --- Logging ---
LOG_LEVEL=info

# --- Version ---
# Pin to a specific release tag
VERSION=latest
REGISTRY=ghcr.io/dinesh-g1

# --- Resource Limits ---
DB_MEMORY_LIMIT=2G
API_MEMORY_LIMIT=1G
DASHBOARD_MEMORY_LIMIT=512M

# --- Audit ---
AUDIT_RETENTION_DAYS=90

# --- License (Enterprise) ---
# LICENSE_KEY=your-enterprise-license-key

# --- OpenTelemetry (Optional) ---
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=your-otel-collector:4317
# OTEL_TRACES_ENABLED=true
# OTEL_METRICS_ENABLED=true
