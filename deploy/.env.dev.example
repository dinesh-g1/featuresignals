# Dev environment configuration (Utho Bangalore — for full-stack development/testing)
#
# This is a PRIMARY region configuration, meaning it serves:
#   - API (api.dev.featuresignals.com)
#   - Dashboard (app.dev.featuresignals.com)
#   - Marketing Website (dev.featuresignals.com)
#   - Documentation (docs.dev.featuresignals.com)
#
# Copy this to .env on your dev VPS and fill in the values.

# --- Region ---
REGION=dev
DOMAIN_API=api.dev.featuresignals.com
DOMAIN_APP=app.dev.featuresignals.com

# CRITICAL: Set DOMAIN_MAIN to make this a PRIMARY region (enables website + docs)
DOMAIN_MAIN=dev.featuresignals.com
DOMAIN_DOCS=docs.dev.featuresignals.com

# --- PostgreSQL ---
POSTGRES_PASSWORD=
DB_ADMIN_PASSWORD=
DB_READONLY_PASSWORD=

# --- API Server ---
JWT_SECRET=
LOG_LEVEL=debug

# --- Payment Gateways (test mode for dev) ---
PAYMENT_GATEWAY=stripe
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_MODE=test

# --- Email (ZeptoMail) ---
EMAIL_PROVIDER=none
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM_EMAIL=noreply@featuresignals.com
ZEPTOMAIL_FROM_NAME=FeatureSignals (Dev)
ZEPTOMAIL_BASE_URL=https://api.zeptomail.in

# --- OpenTelemetry / SigNoz ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.in2.signoz.cloud:443
OTEL_INGESTION_KEY=
OTEL_SERVICE_NAME=featuresignals-api-dev
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=true
OTEL_LOG_LEVEL=debug
OTEL_TRACE_SAMPLE_RATE=1.0
