# ──────────────────────────────────────────────────────────────────────────────
# FeatureSignals Cell Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env on the cell VPS and fill in the values.
#   scp .env.cell.example root@<CELL_IP>:/opt/featuresignals/.env
#
# Required variables are marked with ⚠️
# Optional variables have safe defaults shown.
# ──────────────────────────────────────────────────────────────────────────────

# ── Cell Identity ─────────────────────────────────────────────────────────────
# The domain name for this cell. API at api.{DOMAIN}, Dashboard at app.{DOMAIN}.
DOMAIN=featuresignals.com

# The version tag for server and dashboard images (leave as "latest" for auto)
FEATURESIGNALS_VERSION=latest

# API URL exposed to the dashboard
API_URL=https://api.featuresignals.com

# ── Database ⚠️ ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme-this-is-required
DB_ADMIN_PASSWORD=changeme-this-is-required
DB_READONLY_PASSWORD=changeme-this-is-required

# ── Authentication ⚠️ ─────────────────────────────────────────────────────────
JWT_SECRET=changeme-generate-with-openssl-rand-base64-48

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://app.featuresignals.com,https://featuresignals.com,https://docs.featuresignals.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_BASE_URL=https://featuresignals.com
DASHBOARD_URL=https://app.featuresignals.com

# ── Payment (optional — omit or set to empty to disable billing) ──────────────
# PAYU_MERCHANT_KEY=
# PAYU_SALT=
# PAYU_MODE=live
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# STRIPE_MODE=live

# ── Email (optional — set EMAIL_PROVIDER=none to disable) ─────────────────────
EMAIL_PROVIDER=none
# ZEPTOMAIL_TOKEN=
# ZEPTOMAIL_FROM_EMAIL=noreply@featuresignals.com
# ZEPTOMAIL_FROM_NAME=FeatureSignals
# ZEPTOMAIL_BASE_URL=https://api.zeptomail.in

# ── Observability (optional — defaults to disabled) ──────────────────────────
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_INGESTION_KEY=
# OTEL_SERVICE_NAME=featuresignals-cell
# OTEL_SERVICE_REGION=eu
# OTEL_TRACES_ENABLED=false
# OTEL_METRICS_ENABLED=false
# OTEL_LOGS_ENABLED=false
# OTEL_LOG_LEVEL=warn
# OTEL_TRACE_SAMPLE_RATE=0.1

# ── Cloudflare (optional — for DNS-01 challenge with Caddy) ──────────────────
# CF_API_TOKEN=
