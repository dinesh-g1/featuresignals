# Pass hcloud_token via env var: TF_VAR_hcloud_token="..." terraform apply
# Use per-region .tfvars files: terraform apply -var-file=us.tfvars
#
# Concrete tfvars for US and EU are provided as us.tfvars and eu.tfvars.
# This file documents all available variables.

# --- Required ---
# region       = "us"              # Deployment region (us, eu, dev)
# location     = "ash"             # Hetzner DC (ash=US, fsn1=EU-DE, hel1=EU-FI)
# domain_api   = "api.us.featuresignals.com"
# domain_app   = "app.us.featuresignals.com"

# --- Optional (defaults shown) ---
# server_type  = "cax21"           # cax21=4vCPU/8GB ARM, cpx21=3vCPU/4GB, cpx31=4vCPU/8GB
# ssh_key_name = "featuresignals-deploy"
# volume_size  = 20                # Persistent volume in GB for PostgreSQL data
