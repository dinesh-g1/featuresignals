# FeatureSignals Server — Local Development Environment
# Copy this file:  cp .env.example .env
# Then adjust values as needed.

# ─── Database ────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults. Change only if you use a custom setup.
# Local dev uses sslmode=disable; in production use sslmode=require (or your provider's TLS settings).
DATABASE_URL=postgres://fs:fsdev@localhost:5432/featuresignals?sslmode=disable

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ─── Authentication ──────────────────────────────────────────────────────────
# CHANGE THIS in production. Any string works for local dev.
JWT_SECRET=dev-secret-change-in-production
TOKEN_TTL_MINUTES=60
REFRESH_TTL_HOURS=168

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=debug

# ─── Deployment Mode ──────────────────────────────────────────────────────────
# "cloud" (default) for SaaS, "onprem" for self-hosted
DEPLOYMENT_MODE=cloud

# ─── Email Provider ──────────────────────────────────────────────────────────
# "zeptomail" (default), "smtp" (on-prem), or "none"
EMAIL_PROVIDER=zeptomail

# ─── ZeptoMail (when EMAIL_PROVIDER=zeptomail) ──────────────────────────────
# Zoho ZeptoMail for transactional email delivery (OTP + lifecycle).
# Sign up at https://zeptomail.zoho.com, create an Agent, copy the Send Mail Token.
ZEPTOMAIL_TOKEN=your-zeptomail-send-mail-token
ZEPTOMAIL_FROM_EMAIL=noreply@featuresignals.com
ZEPTOMAIL_FROM_NAME=FeatureSignals
ZEPTOMAIL_BASE_URL=https://api.zeptomail.in

# ─── SMTP (when EMAIL_PROVIDER=smtp) ─────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=FeatureSignals


# ─── URLs ────────────────────────────────────────────────────────────────────
# APP_BASE_URL=http://localhost:8080
# DASHBOARD_URL=http://localhost:3000

# ─── Multi-Region ─────────────────────────────────────────────────────────────
# Identifies which region this server instance serves.
# Used for JWT claims, telemetry, and audit logging — not for routing.
# LOCAL_REGION=in

# ─── PayU Billing ────────────────────────────────────────────────────────────
# PAYU_MERCHANT_KEY=your-payu-key
# PAYU_SALT=your-payu-salt
# PAYU_MODE=test

# ─── Stripe Billing ──────────────────────────────────────────────────────────
# Sign up at https://stripe.com to get your API keys.
# Use sk_test_... keys for local development.
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# STRIPE_PRICE_ID=price_your-pro-plan-price-id
# STRIPE_MODE=test

# ─── Sales Inquiry Notification ──────────────────────────────────────────────
# Email address that receives contact form / sales inquiry submissions.
SALES_NOTIFY_EMAIL=sales@featuresignals.com

# ─── Super Mode (Internal Developer Access) ─────────────────────────────────
# Server-controlled activation for internal developer tools panel.
# No database changes needed — matching users get tier=internal in login response.
# SUPER_MODE_DOMAIN: all users with this email domain get access (e.g., featuresignals.com)
# SUPER_MODE_EMAILS: comma-separated explicit allowlist for non-domain emails
# SUPER_MODE_DOMAIN=featuresignals.com
# SUPER_MODE_EMAILS=dev@gmail.com,contractor@corp.co

# ─── OpenTelemetry / SigNoz ──────────────────────────────────────────────────
# Set OTEL_ENABLED=true and configure endpoint to send telemetry to SigNoz.
# All exports are async (BatchSpanProcessor / PeriodicReader) — zero perf impact when disabled.
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.YOUR_TENANT.signoz.cloud:443
# OTEL_INGESTION_KEY=your-signoz-ingestion-key
OTEL_SERVICE_NAME=featuresignals-api
OTEL_SERVICE_REGION=local
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=true
OTEL_LOG_LEVEL=debug
OTEL_TRACE_SAMPLE_RATE=1.0

# ─── Event Bus ──────────────────────────────────────────────────────────────
# Pluggable event bus for inter-service messaging. Supported providers:
#   noop — No-op event bus; messages are silently discarded (default, no deps)
#   nats — NATS messaging system; requires a running NATS server
EVENT_BUS_PROVIDER=noop
# NATS_URL is required when EVENT_BUS_PROVIDER=nats.
NATS_URL=nats://localhost:4222

# ─── Policy Evaluator (Governance Pipeline) ─────────────────────────────────
# Maximum number of governance policies evaluated per agent action.
# Beyond this limit, remaining policies are skipped to avoid CPU exhaustion.
POLICY_EVAL_MAX_POLICIES=50
# CEL expression evaluation timeout in milliseconds. Individual CEL expressions
# that exceed this timeout are terminated and treated as evaluation failures.
POLICY_EVAL_TIMEOUT_MS=10

# ─── AI Janitor (LLM Code Analysis) ────────────────────────────────────────
# DeepSeek is the default LLM provider for code analysis.
# Set DEEPSEEK_API_KEY to enable AI-powered stale flag detection and PR generation.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI (alternative provider)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ENDPOINT=https://api.openai.com/v1

# Azure OpenAI (enterprise alternative)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_MODEL=gpt-4o

# Janitor LLM settings
JANITOR_LLM_TIMEOUT_SECONDS=30
JANITOR_LLM_MAX_RETRIES=3
JANITOR_LLM_MIN_CONFIDENCE=0.85

# ─── Agent Runtime ──────────────────────────────────────────────────────────
# Heartbeat interval for agent health monitoring (seconds)
AGENT_HEARTBEAT_INTERVAL_SEC=30
# Time after which a silent agent is marked stale (seconds)
AGENT_STALE_TIMEOUT_SEC=120

# ─── Workflow Engine ────────────────────────────────────────────────────────
# Maximum concurrent workflow executions
WORKFLOW_MAX_CONCURRENT=50
# Default workflow timeout (seconds) — individual workflows can override
WORKFLOW_DEFAULT_TIMEOUT_SEC=300
# Maximum retries for failed workflow nodes
WORKFLOW_MAX_RETRIES=3

# ─── Governance Pipeline ────────────────────────────────────────────────────
# Per-step execution timeout in milliseconds (default: 10)
PIPELINE_STEP_TIMEOUT_MS=10
