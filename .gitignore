# Private documentation and sensitive business data (compliance, strategy, operations)
# These files contain confidential information and must not be pushed to public repositories
private/
.internal/

# LLM Wiki — private business knowledge (pricing, competitive intel, customers, roadmap)
# gitignore so they never leak to public repo
product/wiki/private/

# LLM Wiki — internal ops knowledge (infra secrets, runbooks, incidents, compliance gaps)
# Encrypted via git-crypt. This entry ensures unencrypted duplicates are ignored.
product/wiki/internal/

# Claude local settings
.claude/settings.local.json

# Screenshots and browser test images — must never be committed
*.png

# Agentic prompt planning files
PHASE1_PLAN.md
