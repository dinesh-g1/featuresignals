# Caddyfile for isolated customer VPS
# Automatic HTTPS via Let's Encrypt

{{ caddy_subdomain }} {
    # Reverse proxy to dashboard
    handle /dashboard* {
        reverse_proxy fs-dashboard:3000
    }

    # Reverse proxy to API
    handle /api* {
        reverse_proxy fs-server:8080
    }

    # Reverse proxy to API for v1 paths
    handle /v1* {
        reverse_proxy fs-server:8080
    }

    # Health check endpoint
    handle /health {
        reverse_proxy fs-server:8080
    }

    # Default: serve dashboard
    handle {
        reverse_proxy fs-dashboard:3000
    }

    # Logging
    log {
        output stdout
        format json
        level info
    }

    # TLS settings
    tls {
        protocols tls1.2 tls1.3
    }
}

# Redirect www to naked domain
www.{{ caddy_subdomain }} {
    redir https://{{ caddy_subdomain }}{uri} permanent
}
