# ─── FeatureSignals Ops Portal — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env files to version control.

# ─── API Configuration ──────────────────────────────────────────────────────

# Base URL for the Ops API backend
# In development, this is typically the local Go server
NEXT_PUBLIC_OPS_API_URL=http://localhost:8080/api/v1/ops

# ─── Authentication ─────────────────────────────────────────────────────────

# JWT secret used to sign tokens (must match the backend)
# This is required for token verification in middleware
OPS_JWT_SECRET=change-me-to-a-secure-random-secret

# ─── Deployment ─────────────────────────────────────────────────────────────

# The URL where this portal is deployed (used for redirects, CORS, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Feature Flags ──────────────────────────────────────────────────────────

# Enable/disable the SigNoz embedded iframe on the System Health page
NEXT_PUBLIC_SIGNOZ_ENABLED=false

# SigNoz dashboard URL for the embedded iframe (if enabled)
NEXT_PUBLIC_SIGNOZ_IFRAME_URL=

# ─── Observability ──────────────────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog API key for product analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog API host (optional)
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Defaults ───────────────────────────────────────────────────────────────

# Default pagination limit for list endpoints
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=50
